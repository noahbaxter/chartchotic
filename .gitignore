# =============================================================================
# Chart Preview .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Build Artifacts
# -----------------------------------------------------------------------------
**/build/
**/DerivedData/
**/x64/
**/Debug/
**/Release/

# Legacy Projucer paths (safe to remove after confirming CMake works)
**/Builds/
**/JuceLibraryCode/

# -----------------------------------------------------------------------------
# Compiled Binaries
# -----------------------------------------------------------------------------
*.exe
*.dll
*.dylib
*.so
*.app
*.vst3
*.component
*.lib
*.a

# -----------------------------------------------------------------------------
# Development Files
# -----------------------------------------------------------------------------
*.o
*.obj
*.d
*.pch
*.gch
*.opensdf
*.sdf
*.log

# -----------------------------------------------------------------------------
# IDE/Editor Files
# -----------------------------------------------------------------------------
# Xcode
**/*xcuserdata/
**/*.xcuserstate

# Visual Studio
**/*.user
**/*.suo

# VS Code
.vscode/

# CMake
CMakeUserPresets.json

# -----------------------------------------------------------------------------
# Operating System Files
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
Icon
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Project-Specific (Legacy Paths - Now Moved)
# -----------------------------------------------------------------------------
ableton-test Project
reaper-test
DO NOT DISTRIBUTE

# -----------------------------------------------------------------------------
# REAPER Files
# -----------------------------------------------------------------------------
*.rpp-bak
*.rpp-UNDO
*.RPP-UNDO
**/peaks/

# Example/test DAW projects (local only)
examples/

# -----------------------------------------------------------------------------
# Third-Party Dependencies
# -----------------------------------------------------------------------------
# JUCE is a git submodule — don't ignore it
# REAPER SDK header is copied at build time from .ci/reaper-headers/
/third_party/reaper-sdk/
!/third_party/JUCE
!/third_party/README.md
!/third_party/.gitkeep

# Legacy patterns
**/third_party/vst2sdk/
**/third_party/sws/
**/third_party/JUCE-reaper-embedded-fx-gui/
*.zip

# Development/Analysis Notes
*_ANALYSIS.md

# -----------------------------------------------------------------------------
# Python
.venv/
__pycache__/
*.pyc

# AI stuff
sessions/
.claude/
.claude-code/
